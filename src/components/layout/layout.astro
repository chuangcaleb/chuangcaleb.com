---
import Footer from './footer.astro';
import Header from './header.astro';
import SITE from '~/data/site.ts';
import '~/styles/index.css';

interface Props {
	title?: string | null;
	description?: string;
	forehead?: boolean;
}

const {title: propsTitle, description: propsDescription, forehead = false} = Astro.props;

const {pathname} = Astro.url;
const isHome = pathname === '/';
const isNotesRoute = pathname.startsWith('/notes');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const title = propsTitle
	? propsTitle + (isHome ? '' : ` | ${SITE.title}`)
	: SITE.title;
const description
	= propsDescription
		?? (isNotesRoute ? SITE.siteDescriptionFallback : SITE.description);
---

<html lang={SITE.language}>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<meta name='generator' content={Astro.generator} />

		<!-- SEO -->
		<title>{title}</title>
		<meta name='title' content={title} />
		<meta name='description' content={description} />
		<meta name='author' content={SITE.author.name} />
		<link rel='canonical' href={canonicalUrl.href} />
		<link rel='sitemap' href='/sitemap-index.xml' />

		<!-- Open Graph -->
		<meta property='og:type' content='website' />
		<meta property='og:title' content={title} />
		<meta property='og:site_name' content={SITE.title} />
		<meta property='og:url' content={canonicalUrl.href} />
		{description && <meta property='og:description' content={description} />}

		<!-- Twitter -->
		<meta property='twitter:card' content='summary' />
		<meta property='twitter:title' content={title} />
		{
			description && (
				<meta property='twitter:description' content={description} />
			)
		}

		<!-- Theme color (light-only) -->
		<meta name='theme-color' content='#f5f4ed' />

		<slot name='head' />
	</head>
	<body>
		<Header />
		<main id='main' class:list={[forehead ? '' : 'no-forehead']}>
			<slot />
		</main>
		<Footer/>
	</body>
</html>

<style>
	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
	main {
		padding-block: var(--space-3xl);
		max-width: var(--max-page);
		width: 100%;
		margin: 0 auto;
		animation: fadeIn 0.4s ease-out;
	}
	.no-forehead {
		padding-block-start: 0;
	}

	.skip-link {
		position: fixed;
		padding: var(--space-s);
		z-index: 10;
		color: var(--accent);
		background: var(--bg-page);
		border-radius: var(--radius-sm);
		transition: transform 0.3s;
		transform: translateY(-100%);
	}

	.skip-link:focus {
		transform: translateY(0%);
	}
</style>
