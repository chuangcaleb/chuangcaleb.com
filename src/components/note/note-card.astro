---
import type {SuperNote} from 'lib/utils/types';
import NoteTag from '~/components/note/note-tag.astro';
import {noteToTags} from '~/utils/note-metadata.ts';

interface Props {
	note: SuperNote
}

const {note} = Astro.props;
const {route, title} = note;
const tags = noteToTags(note.data);
---

<article class='flow-2xs'>
	<p>
		<a href={route}>
			{title}
		</a>
	</p>
	<ul class='note-tags cluster' aria-label='metadata' role='list'>
		{
			tags.map(tag => (
				<li>
					<NoteTag {...tag} />
				</li>
			))
		}
	</ul>
</article>

<style>
	.note-tags {
		--cluster-gap: var(--space-xs);
	}
	p {
		/* font-size: var(--text-h3); */
		line-height: var(--leading-item);
	}
</style>
