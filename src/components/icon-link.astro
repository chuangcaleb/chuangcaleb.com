---
import {Icon} from 'astro-icon/components';
import {SOCIALS} from '~/data/links.ts';

type Props = Omit<(typeof SOCIALS)['string'], 'userId'>;

const {href, label, icon} = Astro.props;
---

<a href={href} aria-label={label}>
	<Icon name={icon} />
	<span class='label'>{label}</span>
</a>

<style>
  a {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .label {
    margin-inline-start: calc(var(--icon-size, var(--space-l)) * 0.33);
  }
</style>
