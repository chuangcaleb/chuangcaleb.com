---
import {Icon} from 'astro-icon/components';
import {SOCIALS} from '~/data/links.ts';

type Props = Omit<(typeof SOCIALS)['string'], 'userId'> & {isMono?: boolean};

const {href, label, icon, isMono = false} = Astro.props;
---

<a href={href} aria-label={label}>
	<Icon name={icon} />
	<span class:list={['label', isMono && 'mono']}>{label}</span>
</a>

<style>
  a {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .label {
    margin-inline-start: calc(var(--icon-size, var(--space-l)) * 0.33);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: calc(1em * var(--font-mono-scale));
  }
</style>
