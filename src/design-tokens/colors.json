{
  "color": {
    "$type": "color",

    "surface": {
      "default": {
        "$value": "{color.white}"
      },
      "raised": {
        "$value": "{color.white}"
      },
      "lowered": {
        "$value": "{color.neutral.100}"
      },
      "lowest": {
        "$value": "{color.neutral.200}"
      },
      "border": {
        "$value": "{color.neutral.200}"
      }
    },

    "text": {
      "normal": {
        "$value": "{color.neutral.900}"
      },
      "quiet": {
        "$value": "{color.neutral.600}"
      },
      "quieter": {
        "$value": "{color.neutral.500}"
      },
      "placeholder": {
        "$value": "{color.neutral.500}"
      },
      "link": {
        "$value": "{color.neutral.950}"
      }
    },

    "fill": {
      "quiet": {
        "$value": "{color.neutral.fill.quiet}"
      },
      "normal": {
        "$value": "{color.neutral.fill.normal}"
      },
      "loud": {
        "$value": "{color.neutral.fill.loud}"
      }
    },
    "on": {
      "quiet": {
        "$value": "{color.neutral.on.quiet}"
      },
      "normal": {
        "$value": "{color.neutral.on.normal}"
      },
      "loud": {
        "$value": "{color.neutral.on.loud}"
      }
    },
    "border": {
      "quiet": {
        "$value": "{color.neutral.border.quiet}"
      },
      "normal": {
        "$value": "{color.neutral.border.normal}"
      },
      "loud": {
        "$value": "{color.neutral.border.loud}"
      }
    },

    "neutral": {
      "fill": {
        "quiet": {
          "$value": "{color.neutral.50}"
        },
        "normal": {
          "$value": "{color.neutral.100}"
        },
        "loud": {
          "$value": "{color.neutral.800}"
        }
      },
      "on": {
        "quiet": {
          "$value": "{color.neutral.950}"
        },
        "normal": {
          "$value": "{color.neutral.950}"
        },
        "loud": {
          "$value": "{color.neutral.50}"
        }
      },
      "border": {
        "quiet": {
          "$value": "{color.neutral.100}"
        },
        "normal": {
          "$value": "{color.neutral.200}"
        },
        "loud": {
          "$value": "{color.neutral.300}"
        }
      },
      "link": {
        "$value": "{color.neutral.950}"
      }
    },

    "accent": {
      "fill": {
        "quiet": {
          "$value": "{color.pink.50}"
        },
        "normal": {
          "$value": "{color.pink.100}"
        },
        "loud": {
          "$value": "{color.pink.600}"
        }
      },
      "on": {
        "quiet": {
          "$value": "{color.pink.700}"
        },
        "normal": {
          "$value": "{color.pink.700}"
        },
        "loud": {
          "$value": "{color.pink.50}"
        }
      },
      "border": {
        "quiet": {
          "$value": "{color.pink.100}"
        },
        "normal": {
          "$value": "{color.pink.200}"
        },
        "loud": {
          "$value": "{color.pink.300}"
        }
      }
    },

    "transparent": {
      "$value": "{color.alpha.black.00}"
    },
    "white": {
      "$value": "#FFFFFF"
    },
    "black": {
      "$value": "#000000"
    },
    "overlay": {
      "$value": "{color.alpha.black.50}"
    }
  }
}
