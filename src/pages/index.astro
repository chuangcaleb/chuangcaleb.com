---
import Hero from './_components/hero.astro';
import Overview from './_components/overview/index.astro';
import Experience from './_components/experience/index.astro';
import Projects from './_components/projects/index.astro';
// import FeaturedSection from './_components/FeaturedSection.astro';
import Layout from '~/components/layout/layout.astro';
import SITE from '~/data/site.ts';
---

<Layout
	title={`${SITE.title} - ${SITE.subtitle}`}
	description={SITE.description}
	forehead
>
	<Hero />
	<Overview />
	<Experience />
	<Projects />
	<!-- <FeaturedSection /> -->
</Layout>

<style>
	& :global(img):not(:hover) {
		filter: sepia(0.12) saturate(0.85);
	}
</style>
