---
import {Icon} from 'astro-icon/components';
import {Picture} from 'astro:assets';
import {Content as HeroBodyContent} from './_hero-body.mdx';
import profileImg from '~/assets/img/profile.jpg';
import Button from '~/components/button.astro';
import Tagline from '~/components/emphasis/tagline.astro';
import IconLink from '~/components/icon-link.astro';
import {SOCIALS} from '~/data/links.ts';
import Caps from '~/components/emphasis/caps.astro';

const linkSocials = [SOCIALS.LINKEDIN, SOCIALS.GITHUB];
---

<section class='region flow wrapper' style={{'--flow-space': 'var(--space-s)'}}>
	<span class='eyebrow cluster' style={{'--cluster-gap-x': 'var(--space-s)', '--cluster-gap-y': '0'}}>
		<Caps><Icon name='lucide:code' />software engineer</Caps>
		<span aria-hidden='true'>⋅</span>
		<Caps><Icon name='lucide:drama' />narrative author</Caps>
	</span>
	<div
		class='switcher'
		style={{
			'--switcher-inline-at': '100ch',
			'--switcher-gap': 'var(--space-xl)',
		}}
	>
		<div class='hero-text flow max-prose' style={{'--flow-space': 'var(--space-l)'}}>
			<h1 class='hero-name'>Chuang Caleb</h1>
			<div class='flow prose' style={{'--flow-space': 'var(--space-l)'}}>
				<Tagline>
					<HeroBodyContent />
				</Tagline>
				<div class='hero-cta cluster'>
					<Button as='a' variant='primary' href={SOCIALS.EMAIL.href}>
						<Icon name={SOCIALS.EMAIL.icon} height={24} />email me
					</Button>
					<Button as='a' variant='secondary' href={SOCIALS.CV.href}>
						<Icon name={SOCIALS.CV.icon} height={24} />my resume
					</Button>
				</div>
			</div>
			<hr />
			<div
				class='hero-socials cluster'
				style={{
					'--region-space': 'var(--space-xl)',
					'--cluster-gap-x': 'var(--space-s)',
				}}
			>
				{
					linkSocials.map((link, index) => (
						<>
							<IconLink {...link} />
							{index !== Object.keys(linkSocials).length - 1 && (
								<span aria-hidden='true'>⋅</span>
							)}
						</>
					))
				}
				<span aria-hidden='true'>⋅</span>
				<code class='email'>{SOCIALS.EMAIL.userId}</code>
			</div>
		</div>
		<div class='hero-image'>
			<Picture
				src={profileImg}
				alt='Facial profile picture of Chuang Caleb'
				sizes='(max-width: 600px) 80vw, 330px'
				widths={[140, 280, 400, 660]}
				formats={['avif', 'webp']}
				loading='eager'
			/>
		</div>
	</div>
</section>

<style>
  section {
    padding-top: 0;
  }

  .hero-name {
    font-family: var(--font-heading);
    font-size: var(--text-display);
    font-weight: var(--weight-heading);
    line-height: var(--leading-tight);
    color: var(--text-strong);
		margin: 0;
  }

  .hero-image {
    position: relative;
    max-width: fit-content;
  }

  .hero-image img,
  .hero-image picture {
    display: block;
    width: 100%;
    border-radius: var(--radius-md);
    filter: sepia(0.15) saturate(0.9);
  }

  .hero-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--bg-page);
    opacity: 0.12;
    border-radius: inherit;
    pointer-events: none;
  }
	.eyebrow {
		--icon-size: 1.25em;
		width: 100%;
	}

	.email {
		color: var(--text-muted);
		font-size: var(--text-caption);
	}
  /* mark {
    animation: 3s highlight 0.5s 1 ease-out forwards;
    background: linear-gradient(90deg, var(--accent) 50%, var(--bg-page) 50%);
    background-size: 205% 100%;
    background-position: 100% 0;
  }
  @keyframes highlight {
    to {
      background-position: 0 0;
    }
  } */
</style>
