---
import {Icon} from 'astro-icon/components';
import {Picture} from 'astro:assets';
import {Content as HeroBodyContent} from './_hero-body.mdx';
import profileImg from '~/assets/img/profile.jpg';
import Button from '~/components/button.astro';
import Tagline from '~/components/emphasis/tagline.astro';
import SocialLink from '~/components/social-link.astro';
import {SOCIALS} from '~/data/links.ts';
import Caps from '~/components/emphasis/caps.astro';
---

<section class='region flow wrapper' style={{'--flow-space': 'var(--space-sm)'}}>
	<span class='eyebrow cluster' style={{'--cluster-gap': 'var(--space-md)'}}>
		<Caps><Icon name='lucide:code' />software engineer</Caps>
		<span>⋅</span>
		<Caps><Icon name='lucide:drama' />narrative author</Caps>
	</span>
	<div
		class='switcher'
		style={{
			'--switcher-inline-at': '100ch',
			'--switcher-gap': 'var(--space-xl)',
		}}
	>
		<div class='hero-text flow' style={{'--flow-space': 'var(--space-lg)'}}>
			<h1 class='hero-name'>Chuang Caleb</h1>
			<div class='flow prose'>
				<Tagline>
					<HeroBodyContent />
				</Tagline>
				<div class='hero-cta cluster'>
					<Button as='a' variant='primary' href={SOCIALS.EMAIL.href}>
						<Icon name={SOCIALS.EMAIL.icon} height={24} /> email me
					</Button>
					<Button as='a' variant='secondary' href='#projects'>
						<Icon name='lucide:atom' height={24} /> see projects
					</Button>
				</div>
			</div>
			<hr />
			<div
				class='hero-socials cluster'
				style={{
					'--region-space': 'var(--space-xl)',
					'--cluster-gap-y': 'var(--space-sm)',
				}}
			>
				{
					Object.values(SOCIALS).map((link, index) => (
						<>
							<SocialLink href={link.href} label={link.label}>
								<Icon name={link.icon} />
							</SocialLink>
							{index !== Object.keys(SOCIALS).length - 1 && (
								<span aria-hidden='true'>⋅</span>
							)}
						</>
					))
				}
			</div>
		</div>
		<div class='hero-image'>
			<Picture
				src={profileImg}
				alt='Facial profile picture of Chuang Caleb'
				sizes='(max-width: 700px) 50vw, 320px'
				widths={[140, 280, 400, 560]}
				formats={['avif', 'webp']}
				loading='eager'
			/>
		</div>
	</div>
</section>

<style>
  section {
    align-items: center;
    padding-top: 0;
    position: relative;
  }

  .hero-name {
    font-family: var(--font-heading,);
    font-size: var(--text-display,);
    font-weight: var(--weight-heading);
    line-height: var(--leading-tight);
    color: var(--text-strong);
		margin: 0;
  }

  .hero-image {
    position: relative;
    max-width: 38ch;
  }

  .hero-image img,
  .hero-image picture {
    display: block;
    width: 100%;
    border-radius: var(--radius-md);
    filter: sepia(0.15) saturate(0.9);
  }

  .hero-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--bg-page);
    opacity: 0.12;
    border-radius: inherit;
    pointer-events: none;
  }
	.eyebrow {
		width: 100%;
	}

  mark {
    animation: 3s highlight 0.5s 1 ease-out forwards;
    background: linear-gradient(90deg, var(--accent) 50%, var(--bg-page) 50%);
    background-size: 205% 100%;
    background-position: 100% 0;
  }
  @keyframes highlight {
    to {
      background-position: 0 0;
    }
  }
</style>
