---
import {parse} from 'date-fns';
import type {GuestPost} from 'lib/google/sheets/types.js';
import Caps from '~/components/emphasis/caps.astro';
import Tag from '~/components/tag.astro';
import {getGeneratedAvatarUrl} from '~/utils/avatar.ts';
import {formatIso} from '~/utils/time.ts';

interface Props {
	post: GuestPost;
}

const {post} = Astro.props;

const hasLink = Boolean(post['🔗 Social Link']);

const avatarSrc = post['📸 Avatar Image Link']
	|| getGeneratedAvatarUrl(post['📇 Display Name']);

const formattedDate = formatIso(
	parse(post.Timestamp, 'dd/MM/yyyy HH:mm:ss', new Date()).toISOString(),
	'MMMM yyyy',
);
---

<div class='flow-s'>
	<div class='cluster' style='gap: var(--space-s)'>
		<img
			class='avatar'
			src={avatarSrc}
			alt={`Avatar of ${post['📇 Display Name']}`}
			height={40}
			width={40}
			fetchpriority='low'
			loading='lazy'
		/>
		<header>
			{
				hasLink
					? (
						<a href={post['🔗 Social Link']} rel='noopener noreferrer'>
							{post['📇 Display Name']}
						</a>
					)
					: (
						<p>{post['📇 Display Name']}</p>
					)
			}
			<span class='meta cluster' style='column-gap: var(--space-s)'>
				<span>{post['👥 Relation to me']}</span>
				{post['🏷️ Tag'] !== 'Other' && <Tag>#{post['🏷️ Tag']}</Tag>}
			</span>
		</header>
	</div>
	<p class='body'>
		{post['📃 Content Body']}
	</p>
	<p>
		<Caps>
			<time class='date' datetime={parse(post.Timestamp, 'dd/MM/yyyy HH:mm:ss', new Date()).toISOString()}>
				{formattedDate}
			</time>
		</Caps>
	</p>
</div>

<style>
	.avatar {
		height: 2.5em;
		width: 2.5em;
		aspect-ratio: 1;
		border-radius: var(--radius-full);
		border: var(--border-thin-default);
	}

	.meta {
		font-size: var(--text-caption);
		color: var(--text-muted);
		text-transform: lowercase;
		white-space: nowrap;
	}
</style>
