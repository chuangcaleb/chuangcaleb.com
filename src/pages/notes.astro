---
import {
	getFeaturedNotes,
	getRecentlyModified,
	getRecentlyPublished,
	getTopLevelNotes,
} from 'lib/utils/note-filters.ts';
import Layout from '~/components/layout/layout.astro';
import NotesSection from '~/components/note/notes-section.astro';
import '~/styles/index.css';
import {getAllNotes} from '~/utils/note.ts';

const allNotes = await getAllNotes();

const featured = getFeaturedNotes(allNotes);
const topLevel = getTopLevelNotes(allNotes);

const seen = new Set([
	...featured.map(n => n.id),
	...topLevel.map(n => n.id),
]);

const recentModified = getRecentlyModified(allNotes, seen, 10);

const recentPublished = getRecentlyPublished(
	allNotes,
	new Set([...seen, ...recentModified.map(n => n.id)]),
	6,
);
---

<Layout title='Notes' description=''>
	<section class='wrapper prose flow-s'>
		<h1>Notes</h1>
		<p>Welcome! This "garden" is like a blog, but more fluid!</p>

		<p>I write notes in Obsidian for daily journals and personal knowledge management (PKM) — but I also like to yap about narrative storytelling and sometimes tech stuff, and perhaps you like to listen to yapping...</p>

		<p>So I've exposed some of my notes on this site, especially self-authored content! I'm coming to a MVP, as I refine the exporting script to grab more notes.</p>
	</section>

	<NotesSection
		heading='Featured'
		notes={featured}
	/>

	<NotesSection
		heading='Top-Level Notes'
		notes={topLevel}
	/>

	<NotesSection
		heading='Recently Published'
		notes={recentPublished}
	/>

	<NotesSection
		heading='Recently Modified'
		notes={recentModified}
		variant='prose'
		showDate='modified'
	/>

</Layout>
