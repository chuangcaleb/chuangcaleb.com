{
	"name": "chuangcaleb.com",
	"type": "module",
	"version": "2.0.0",
	"scripts": {
		"astro": "astro",
		"format:check": "pnpm xo -- --list-different .",
		"format:fix": "pnpm xo --fix .",
		"test": "xo",
		"b2:download": "node lib/b2/index.mjs && tsx lib/chuangcaleb/generate-redirects.ts",
		"setup-external": "pnpm b2:download",
		"dev": "pnpm setup-external && astro dev",
		"dev:nosetup": "astro dev",
		"build": "pnpm setup-external && astro check && astro build && pnpm pagefind",
		"build:nosetup": "astro check && astro build",
		"pagefind": "pagefind --site dist --output-subdir _pagefind",
		"pagefind:dev": "pnpm pagefind && cp -r dist/_pagefind public/",
		"preview:nobuild": "wrangler pages dev ./dist",
		"preview:nosetup": "pnpm build:nosetup && wrangler pages dev ./dist",
		"preview": "pnpm build && wrangler pages dev ./dist"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/mdx": "^7.0.0",
		"@astrojs/react": "^6.0.0",
		"@astrojs/sitemap": "^3.7.3",
		"@iconify-json/lucide": "^1.2.90",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify-json/simple-icons": "^1.2.70",
		"@portaljs/remark-wiki-link": "^1.2.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"astro": "^7.0.4",
		"astro-compressor": "^1.3.0",
		"astro-icon": "^1.1.5",
		"astro-pagefind": "^2.0.0",
		"astro-purgecss": "^7.0.0",
		"astro-robots-txt": "^1.0.0",
		"backblaze-b2": "^1.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"decompress": "^4.2.1",
		"dotenv": "^17.4.2",
		"fs-extra": "^11.3.3",
		"github-slugger": "^2.0.0",
		"google-auth-library": "^10.9.0",
		"google-spreadsheet": "^5.3.0",
		"googleapis": "^173.0.0",
		"js-yaml": "^5.2.0",
		"mdast-util-to-string": "^4.0.0",
		"normalize.css": "^8.0.1",
		"pagefind": "^1.5.2",
		"postcss-custom-media": "^12.0.1",
		"postcss-preset-env": "^11.3.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rehype-external-links": "^3.0.0",
		"sharp": "^0.35.2",
		"typescript": "^6.0.3",
		"unified": "^11.0.5",
		"utopia-core-scss": "^1.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/hast": "^3.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/mdast": "^4.0.4",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/unist": "^3.0.3",
		"astro-og": "^0.3.2",
		"autoprefixer": "^10.5.2",
		"eslint-plugin-astro": "^2.1.1",
		"postcss": "^8.5.16",
		"prettier-plugin-astro": "^0.14.1",
		"sass": "^1.101.0",
		"tsx": "^4.22.4",
		"unist-util-visit": "^5.1.0",
		"xo": "^3.0.2"
	},
	"engines": {
		"node": ">=18.20.8"
	}
}
